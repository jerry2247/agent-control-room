# ============================================================
# Parallax configuration.
# Copy values into your shell, Render environment, or a local .env loader.
# All services are optional. With no credentials, the app runs locally using
# deterministic generation, mock search, inline ETL, and embedded chdb when it
# is available.
# ============================================================

# ---- LLM: query generation, critic audit, synthesis narrative ----
# LLM_BACKEND=truefoundry | anthropic | local   (auto-inferred from keys if unset)
#TRUEFOUNDRY_BASE_URL=https://<your-org>.truefoundry.cloud/api/llm
#TRUEFOUNDRY_API_KEY=tfy-...
#TRUEFOUNDRY_CHAT_MODEL=anthropic-main/claude-sonnet-4-6
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Embeddings (default: deterministic local 256-d hash projection) ----
# Point at any OpenAI-compatible /embeddings endpoint when you want provider
# embeddings instead of the deterministic local embedder.
#EMBEDDING_BACKEND=api
#EMBEDDING_API_BASE=https://<your-org>.truefoundry.cloud/api/llm
#EMBEDDING_API_KEY=tfy-...
#EMBEDDING_MODEL=openai-main/text-embedding-3-small

# ---- Search execution (Composio) ----
# SEARCH_BACKEND=composio | mock   (auto: composio when the key is set)
#COMPOSIO_API_KEY=ak_...
#COMPOSIO_TOOL_SLUG=COMPOSIO_SEARCH_SEARCH
#COMPOSIO_USER_ID=default
#RESULTS_PER_QUERY=5

# ---- ETL (Airbyte) ----
# ETL_BACKEND=inline | airbyte   (airbyte additionally stages JSONL + triggers a sync)
#AIRBYTE_CLIENT_ID=...
#AIRBYTE_CLIENT_SECRET=...
#AIRBYTE_CONNECTION_ID=...
#AIRBYTE_API_BASE=https://api.airbyte.com/v1
#AIRBYTE_STAGING_DIR=.airbyte_staging

# ---- ClickHouse ----
# CLICKHOUSE_MODE=auto | chdb | cloud | memory
#CLICKHOUSE_HOST=<service>.<region>.clickhouse.cloud
#CLICKHOUSE_PORT=8443
#CLICKHOUSE_USER=default
#CLICKHOUSE_PASSWORD=...
#CLICKHOUSE_DATABASE=default
#CHDB_PATH=.chdb_data

# ---- Variance engine ----
#N_QUERIES_DEFAULT=5        # use >= 3: on loaded queries the dialectic pair
                            # (affirm-frame + counter-frame probes) takes 2 slots
#DEFAULT_EPSILON=0          # 0 = auto-optimize epsilon per request (recommended:
                            # auto also widens to admit the dialectic probes;
                            # a fixed radius is respected strictly)
# Frame debiasing (Pillar D) has no switches: presupposition detection, neutral
# recentering, and the frame-balance metric are always on, and activate only
# when a loaded frame is detected.
